{{- $newsSection := site.GetPage "/about/news" -}}
{{- $pages := (where $newsSection.Pages "Kind" "page").ByDate.Reverse -}}
{{- $limit := site.Config.Services.RSS.Limit -}}
{{- if gt $limit 0 }}{{ $pages = $pages | first $limit }}{{ end -}}
{{ "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML }}
<rss xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:atom="http://www.w3.org/2005/Atom" version="2.0">
  <channel>
    <title>{{ i18n "Xfce News" }}</title>
    <description>{{ i18n "Xfce release announcements" }}</description>
    <link>{{ absURL "about/news" }}</link>
    <copyright>Olivier Fourdan 1996 - {{ now.Year }}</copyright>
    <language>{{ .Language.Lang }}</language>
    <generator>Hugo</generator>
    {{- $feedPath := "feed" }}
    {{- if ne .Language.Lang "en" }}{{ $feedPath = printf "%s/feed" .Language.Lang }}{{ end }}
    <atom:link href="{{ $feedPath | absURL }}" rel="self" type="application/rss+xml" />
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <description>{{ printf "<![CDATA[%s]]>" .Summary | plainify }}</description>
      <content:encoded>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content:encoded>
      <link>{{ .Permalink }}</link>
      <dc:creator>{{ with .Params.author }}{{ . }}{{ else }}Release Manager{{ end }}</dc:creator>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 GMT" }}</pubDate>
      <category>Xfce News</category>
      <guid isPermaLink="false">{{ .Permalink }}</guid>
    </item>
    {{- end }}
  </channel>
</rss>
