msgid "This release can be downloaded either as a set of individual packages or as a single fat tarball including all these individual versions:\n"
msgstr "Această versiune poate fi descărcată fie ca un set de pachete individuale, fie ca o singură arhivă comprimată „grasă” care include toate aceste versiuni individuale:\n"

#. type: Plain text
#: content/about/news/1734220800.md:28
#, no-wrap
msgid "<https://archive.xfce.org/xfce/4.20>\n"
msgstr ""

#. type: Plain text
#: content/about/news/1734220800.md:29 content/about/news/1671062400.md:29
