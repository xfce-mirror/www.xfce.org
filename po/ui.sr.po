#: header.php:6 frontpage.php:44
msgid "Xfce Desktop Environment"
msgstr "Радно окружење ИксФЦЕ"

#: header.php:55
msgid "Categories"
msgstr "Врсте"

#: header.php:57
msgid "Navigate"
msgstr "Управљајте"

#: header.php:59
msgid "Home"
msgstr "Почетна"

#: header.php:68 header.php:83
