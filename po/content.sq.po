#. type: Yaml Front Matter Hash Value: title
#: content/about/news/1274572800.md:1
#, no-wrap
msgid "Xfce 4.6.2 released"
msgstr "Është hedhur në qarkullim Xfce 4.6.2"

#. type: Plain text
#: content/about/news/1274572800.md:9
#, markdown-text, no-wrap
msgid ""
"The second bugfix-release of xfce 4.6 has been released.\n"
"This release features a lot of updated translations and fixes some bugs or regressions with new GTK+ versions.\n"
msgstr ""
"Është hedhur në qarkullim hedhja e dytë për ndreqje të metash e xfce 4.6-s.\n"
"Kjo hedhje në qarkullim përmban plot përditësime përkthimesh dhe ndreq disa të meta apo prapakthime me versionet e rinj të GTK+.\n"

#. type: Bullet: '- '
#: content/about/news/1274572800.md:14
#, markdown-text, no-wrap
msgid "[Download](http://archive.xfce.org/xfce/4.6.2/)\n"
msgstr "[Shkarkim](http://archive.xfce.org/xfce/4.6.2/)\n"

#. type: Bullet: '- '
