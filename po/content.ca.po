#: content/about/news/1425081600.md:59 content/about/news/1335571200.md:28
#, no-wrap
msgid "This release can be downloaded either as a set of individual packages or as a single fat tarball including all these individual versions:\n"
msgstr "Aquest llançament es pot descarregar ja sigui com un conjunt de paquets individuals o com un sol tarball de greix incloent totes aquestes versions individuals:\n"

#. type: Plain text
#: content/about/news/1734220800.md:28
#, no-wrap
